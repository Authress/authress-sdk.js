  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Debug tests",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "command": "npm test"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Debug Integration Tests with AWS Credentials",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "command": "eval $(aws-sso eval  --account AWS_ACCOUNT_ID --role AdministratorAccess) && yarn integration"
    }
  ]
}
