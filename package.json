{
  "name": "@authress/sdk",
  "version": "0.0.0",
  "description": "Client SDK for Authress authorization as a service. Provides managed authorization api to secure service resources including user data.",
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "src"
  ],
  "scripts": {
    "lint": "check-dts index.d.ts && eslint --ext .js,.ts,.d.ts tests tests_integration src make.js index.js index.d.ts",
    "test": "vitest run --config vitest.config.js",
    "integration": "vitest run --config vitest.integration.config.js"
  },
  "dependencies": {
    "@authress/login": "*",
    "axios": "*",
    "base64url": "^3.0.1",
    "jose": "^4.8.3",
    "luxon": "3"
  },
  "devDependencies": {
    "@authress/eslint-config": "^2.0.16",
    "@aws-sdk/client-kms": "^3.1000.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "chai": "^4.2.0",
    "check-dts": "^0.7.1",
    "ci-build-tools": "^1.0.13",
    "commander": "^4.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "fs-extra": "^8.1.0",
    "glob": "^7.1.6",
    "sinon": "^7.5.0",
    "travis-build-tools": "~1.2",
    "typescript": "<4.9.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
